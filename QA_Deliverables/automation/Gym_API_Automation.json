  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "requests": {},
        "exec": [
          "// 1. Sinh ID duy nhất tránh trùng lặp",
          "pm.environment.set(\"unique_id\", Date.now());",
          "",
          "// Hàm tự viết để lấy chuỗi YYYY-MM-DD theo chuẩn Local Time (Việt Nam)",
          "function getLocalDateString(date) {",
          "    const y = date.getFullYear();",
          "    const m = (date.getMonth() + 1).toString().padStart(2, '0');",
          "    const d = date.getDate().toString().padStart(2, '0');",
          "    return `${y}-${m}-${d}`;",
          "}",
          "",
          "// 2. Lấy ngày chuẩn Local",
          "const today = new Date();",
          "pm.environment.set(\"today_date\", getLocalDateString(today));",
          "",
          "const tomorrow = new Date(today);",
          "tomorrow.setDate(tomorrow.getDate() + 1);",
          "pm.environment.set(\"future_date\", getLocalDateString(tomorrow));",
          "",
          "// 3. Tính toán Giờ Real-time (Đã chặn lỗi múi giờ qua đêm)",
          "const start = new Date(today.getTime() + 10 * 60000); // Hiện tại + 10p",
          "let startH = start.getHours();",
          "let startM = start.getMinutes();",
          "",
          "let endH = startH + 1;",
          "let endM = startM;",
          "",
          "// Nếu là cú đêm (vắt qua ngày mới) -> Ép cứng về khung giờ an toàn trong ngày hôm nay",
          "if (endH >= 24) {",
          "    startH = 22;",
          "    startM = 0;",
          "    endH = 23;",
          "    endM = 59;",
          "}",
          "",
          "pm.environment.set(\"current_start_time\", startH.toString().padStart(2, '0') + \":\" + startM.toString().padStart(2, '0'));",
          "pm.environment.set(\"current_end_time\", endH.toString().padStart(2, '0') + \":\" + endM.toString().padStart(2, '0'));"
        ]
      }
    },
